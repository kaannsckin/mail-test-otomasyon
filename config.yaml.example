# ============================================================
# config.yaml.example — Bu dosyayı config.yaml olarak kopyala
# cp config.yaml.example config.yaml
# Sonra gerçek değerleri gir (config.yaml .gitignore'da)
# ============================================================

ems:
  smtp_host: "ems.sirket.local"
  smtp_port: 587
  smtp_use_tls: true
  imap_host: "ems.sirket.local"
  imap_port: 993
  imap_use_ssl: true
  username: "testuser@sirket.local"
  password: ""                        # Arayüzden gir
  test_address: "testuser@sirket.local"
  label: "EMS On-Prem"
  auth_method: "password"             # password | app_password | totp_password | otp_only
  mfa_method: "totp"                  # totp | sms | email_otp | push
  totp_secret: ""                     # Opsiyonel — boş bırakırsan her çalışmada manuel girersin

gmail:
  smtp_host: "smtp.gmail.com"
  smtp_port: 587
  smtp_use_tls: true
  imap_host: "imap.gmail.com"
  imap_port: 993
  imap_use_ssl: true
  username: "testuser@gmail.com"
  password: ""
  test_address: "testuser@gmail.com"
  label: "Gmail"
  auth_method: "app_password"
  mfa_method: "totp"
  totp_secret: ""

outlook:
  smtp_host: "smtp.office365.com"
  smtp_port: 587
  smtp_use_tls: true
  imap_host: "outlook.office365.com"
  imap_port: 993
  imap_use_ssl: true
  username: "testuser@sirket.onmicrosoft.com"
  password: ""
  test_address: "testuser@sirket.onmicrosoft.com"
  label: "Outlook / O365"
  auth_method: "password"
  mfa_method: "totp"
  totp_secret: ""

anthropic:
  api_key: ""                         # https://console.anthropic.com → API Keys
  model: "claude-sonnet-4-20250514"

test:
  wait_seconds: 15
  max_retries: 3
  retry_interval: 5
  subject_prefix: "[AUTO-TEST]"
  test_attachment_path: "test_files/test_document.pdf"
  test_image_path: "test_files/test_image.png"
  csv_input: "mail_test_checklist.csv"
  report_output: "reports/test_report.html"
  results_csv: "reports/test_results.csv"

logging:
  level: "INFO"
  file: "logs/automation.log"
